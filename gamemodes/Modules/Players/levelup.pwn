
CMD:levels(playerid, params[])
{
    new output[1000];
    format(output,sizeof(output),"Level\tHours\n");
    for(new i = pData[playerid][pLevel]; i <= 100; i++) strcat(output, sprintf("%d\t%d\n", i, GetHoursLevel(i)));
    Dialog_Show(playerid, ShowOnly, DIALOG_STYLE_TABLIST_HEADERS, "Level Requirement", output, "Close", "", "");
    return 1;
}

