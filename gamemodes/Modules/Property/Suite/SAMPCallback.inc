    return 1;
}

hook OnPlayerEditDynamicObj(playerid, STREAMER_TAG_OBJECT: objectid, response, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz)
{
	if(response == EDIT_RESPONSE_FINAL)
	{ 
        if (EditSuiteStructure[playerid][0] != -1 && EditSuiteStructure[playerid][1] != -1) 
		{
			new suiteid = EditSuiteStructure[playerid][1],
			slot = EditSuiteStructure[playerid][0];
			if (suiteid != -1 && (Owner_SuiteRoom(playerid, suiteid))) {
				if (!IsPointInDynamicArea(SuiteRoom[suiteid][suiteRoomArea], x, y, z))
					return Error(playerid, "You can't place structure outside the suiteroom area"), CancelEdit(playerid), SuiteStructure_Refresh(suiteid, slot);

				SuiteStructure[suiteid][slot][suitestructPos][0] = x;
				SuiteStructure[suiteid][slot][suitestructPos][1] = y;
				SuiteStructure[suiteid][slot][suitestructPos][2] = z;
				SuiteStructure[suiteid][slot][suitestructRot][0] = rx;
				SuiteStructure[suiteid][slot][suitestructRot][1] = ry;
				SuiteStructure[suiteid][slot][suitestructRot][2] = rz;
				
				SetDynamicObjectPos(objectid,x,y,z);
				SetDynamicObjectRot(objectid,rx,ry,rz);
				SuiteStructure_Refresh(suiteid, slot);
				ApartStructure_Save(suiteid, slot, SAVE_STRUCTURE_POS);

				SendCustomMessage(playerid, "SUITEROOM", "You have edited the structure position of \"%s"WHITE_E"\".", GetStructureNameByModel(SuiteStructure[suiteid][slot][suitestructModel]));

				EditSuiteStructure[playerid][0] = -1;
				EditSuiteStructure[playerid][1] = -1;
			}
			return 1;
		}
        if (EditSuiteFurniture[playerid][1] != -1 && EditSuiteFurniture[playerid][0] != -1)
		{
			new suiteid = EditSuiteFurniture[playerid][0],
      		slot = EditSuiteFurniture[playerid][1];
			if (suiteid != -1 && (Owner_SuiteRoom(playerid, suiteid))) {
				if (!IsPointInDynamicArea(SuiteRoom[suiteid][suiteRoomArea], x, y, z))
					return Error(playerid, "You can't place furniture outside the suiteroom area"), CancelEdit(playerid), SuiteFurniture_Refresh(slot, suiteid);
				SuiteFurniture[suiteid][slot][suitefurnPos][0] = x;
				SuiteFurniture[suiteid][slot][suitefurnPos][1] = y;
				SuiteFurniture[suiteid][slot][suitefurnPos][2] = z;
				SuiteFurniture[suiteid][slot][suitefurnRot][0] = rx;
				SuiteFurniture[suiteid][slot][suitefurnRot][1] = ry;
				SuiteFurniture[suiteid][slot][suitefurnRot][2] = rz;
				
				SetDynamicObjectPos(objectid,x,y,z);
				SetDynamicObjectRot(objectid,rx,ry,rz);
				SuiteFurniture_Refresh(slot, suiteid);
				SuiteFurniture_Save(slot, suiteid);

				SendCustomMessage(playerid, "FURNITURE", "You have edited the position of item \"%s"WHITE_E"\".", SuiteFurniture[suiteid][slot][suitefurnName]);

				EditSuiteFurniture[playerid][1] = -1;
				EditSuiteFurniture[playerid][0] = -1;
			}
			return 1;
		}
        if(PlayerEditSuiteRoom[playerid][0] == 1)
		{
			new suiteid = PlayerEditSuiteRoom[playerid][1];
            SuiteRoom[suiteid][suiteRoomDoors][0] = x;
            SuiteRoom[suiteid][suiteRoomDoors][1] = y; 
            SuiteRoom[suiteid][suiteRoomDoors][2] = z;
            SuiteRoom[suiteid][suiteRoomDoors][3] = rx;
            SuiteRoom[suiteid][suiteRoomDoors][4] = ry;
            SuiteRoom[suiteid][suiteRoomDoors][5] = rz;
            SetDynamicObjectPos(objectid,  SuiteRoom[suiteid][suiteRoomDoors][0], SuiteRoom[suiteid][suiteRoomDoors][1], SuiteRoom[suiteid][suiteRoomDoors][2]);
            SetDynamicObjectRot(objectid, SuiteRoom[suiteid][suiteRoomDoors][3], SuiteRoom[suiteid][suiteRoomDoors][4], SuiteRoom[suiteid][suiteRoomDoors][5]);
            SendCustomMessage(playerid, "SUITEROOM", ""AQUA_E"Successfully edit door suite room ID %d", suiteid);
            SuiteRoom_Save(suiteid);
            SuiteRoom_Refresh(suiteid);
            Streamer_UpdateEx(playerid, SuiteRoom[suiteid][suiteRoomDoors][0], SuiteRoom[suiteid][suiteRoomDoors][1], SuiteRoom[suiteid][suiteRoomDoors][2]);
            PlayerEditSuiteRoom[playerid][0] = -1;
            PlayerEditSuiteRoom[playerid][1] = -1;
			return 1;
		}
        if(PlayerEditSuiteRoom[playerid][0] == 2)
		{
			new suiteid = PlayerEditSuiteRoom[playerid][1];
            SuiteRoom[suiteid][suiteRoomButtons][0] = x;
            SuiteRoom[suiteid][suiteRoomButtons][1] = y; 
            SuiteRoom[suiteid][suiteRoomButtons][2] = z;
            SuiteRoom[suiteid][suiteRoomButtons][3] = rx;
            SuiteRoom[suiteid][suiteRoomButtons][4] = ry;
            SuiteRoom[suiteid][suiteRoomButtons][5] = rz;
            SetDynamicObjectPos(objectid,  SuiteRoom[suiteid][suiteRoomButtons][0], SuiteRoom[suiteid][suiteRoomButtons][1], SuiteRoom[suiteid][suiteRoomButtons][2]);
            SetDynamicObjectRot(objectid, SuiteRoom[suiteid][suiteRoomButtons][3], SuiteRoom[suiteid][suiteRoomButtons][4], SuiteRoom[suiteid][suiteRoomButtons][5]);
            SendCustomMessage(playerid, "SUITEROOM", ""AQUA_E"Successfully edit buttons suite room ID %d", suiteid);
            SuiteRoom_Save(suiteid);
            SuiteRoom_Refresh(suiteid);
            Streamer_UpdateEx(playerid, SuiteRoom[suiteid][suiteRoomButtons][0], SuiteRoom[suiteid][suiteRoomButtons][1], SuiteRoom[suiteid][suiteRoomButtons][2]);
            PlayerEditSuiteRoom[playerid][0] = -1;
            PlayerEditSuiteRoom[playerid][1] = -1;
			return 1;
		}
	}
    if(response == EDIT_RESPONSE_CANCEL) {
        if (EditSuiteStructure[playerid][0] != -1 && EditSuiteStructure[playerid][1] != -1) 
		{
			new suiteid = EditSuiteStructure[playerid][1],
			slot = EditSuiteStructure[playerid][0];
			SuiteStructure_Refresh(suiteid, slot);
			EditSuiteStructure[playerid][0] = -1;
			EditSuiteStructure[playerid][1] = -1;
			return 1;
		}
        if (EditSuiteStructure[playerid][0] != -1 && EditSuiteStructure[playerid][1] != -1) 
		{
			new suiteid = EditSuiteStructure[playerid][1],
			slot = EditSuiteStructure[playerid][0];
			SuiteStructure_Refresh(suiteid, slot);
			EditSuiteStructure[playerid][0] = -1;
			EditSuiteStructure[playerid][1] = -1;
			return 1;
		}
        if(PlayerEditSuiteRoom[playerid][0] == 1)
	    {
			new suiteid = PlayerEditSuiteRoom[playerid][1];
			SetDynamicObjectPos(objectid, SuiteRoom[suiteid][suiteRoomButtons][0], SuiteRoom[suiteid][suiteRoomButtons][1], SuiteRoom[suiteid][suiteRoomButtons][2]);
            SetDynamicObjectRot(objectid, SuiteRoom[suiteid][suiteRoomButtons][3], SuiteRoom[suiteid][suiteRoomButtons][4], SuiteRoom[suiteid][suiteRoomButtons][5]);
            PlayerEditSuiteRoom[playerid][0] = -1;
            PlayerEditSuiteRoom[playerid][1] = -1;
			return 1;
		}
        if(PlayerEditSuiteRoom[playerid][0] == 2)
	    {
			new suiteid = PlayerEditSuiteRoom[playerid][1];
			SetDynamicObjectPos(objectid, SuiteRoom[suiteid][suiteRoomButtons][0], SuiteRoom[suiteid][suiteRoomButtons][1], SuiteRoom[suiteid][suiteRoomButtons][2]);
            SetDynamicObjectRot(objectid, SuiteRoom[suiteid][suiteRoomButtons][3], SuiteRoom[suiteid][suiteRoomButtons][4], SuiteRoom[suiteid][suiteRoomButtons][5]);
            PlayerEditSuiteRoom[playerid][0] = -1;
            PlayerEditSuiteRoom[playerid][1] = -1;
			return 1;
		}
    }
	return 0;
}

hook OnPlayerKeyStateChange(playerid, newkeys, oldkeys)
{
	if(GetPlayerState(playerid) == PLAYER_STATE_ONFOOT) if((newkeys & KEY_SECONDARY_ATTACK))
    {
        foreach(new suiteid : SuiteRooms) if(IsPlayerInRangeOfPoint(playerid, 1.5, SuiteRoom[suiteid][suiteRoomButtons][0], SuiteRoom[suiteid][suiteRoomButtons][1], SuiteRoom[suiteid][suiteRoomButtons][2])) {
            if(!Owner_SuiteRoom(playerid, suiteid)) return Error(playerid, "You don't own this suite room");
            switch(SuiteRoom[suiteid][suiteRoomLocked]) {
                case 0: {
                    ApplyAnimation(playerid, "HEIST9", "Use_SwipeCard", 10.0, 0, 0, 0, 0, 0);
                    MoveDynamicObject(SuiteRoom[suiteid][suiteObjectDoors], SuiteRoom[suiteid][suiteRoomDoors][0], SuiteRoom[suiteid][suiteRoomDoors][1]+1.6, SuiteRoom[suiteid][suiteRoomDoors][2], 3.0, SuiteRoom[suiteid][suiteRoomDoors][3], SuiteRoom[suiteid][suiteRoomDoors][4], SuiteRoom[suiteid][suiteRoomDoors][5]);
                    SuiteRoom[suiteid][suiteRoomLocked] = 1;
                }
                case 1: {
                    ApplyAnimation(playerid, "HEIST9", "Use_SwipeCard", 10.0, 0, 0, 0, 0, 0);
                    MoveDynamicObject(SuiteRoom[suiteid][suiteObjectDoors], SuiteRoom[suiteid][suiteRoomDoors][0], SuiteRoom[suiteid][suiteRoomDoors][1], SuiteRoom[suiteid][suiteRoomDoors][2], 3.0, SuiteRoom[suiteid][suiteRoomDoors][3], SuiteRoom[suiteid][suiteRoomDoors][4], SuiteRoom[suiteid][suiteRoomDoors][5]);
                    SuiteRoom[suiteid][suiteRoomLocked] = 0;
                }
            }
        }
    }
	return 1;
}

// Player clicked a dynamic object
hook OnPlayerSelectDynObject(playerid, objectid, modelid, Float:x, Float:y, Float:z)
{
    if (EditSuiteFurniture[playerid][0] != -1) {
		new suiteid = EditSuiteFurniture[playerid][0];
		foreach (new slot : SuiteFurnitures[suiteid]) if (objectid == SuiteFurniture[suiteid][slot][suitefurnObject]) {
            switch (SelectFurnitureType[playerid]) {
                case FURNITURE_SELECT_MOVE: {
                    EditSuiteFurniture[playerid][1] = slot;
                    EditSuiteFurniture[playerid][0] = suiteid;

                    EditDynamicObject(playerid, SuiteFurniture[suiteid][slot][suitefurnObject]);
                    SendCustomMessage(playerid, "FURNITURE", "You are now editing the position of \"%s"WHITE_E"\".", SuiteFurniture[suiteid][slot][suitefurnName]);
                    break;
                }
                case FURNITURE_SELECT_DESTROY: {
                    SendCustomMessage(playerid, "FURNITURE", "You have destroyed furniture \"%s"WHITE_E"\".", SuiteFurniture[suiteid][slot][suitefurnName]);
                    SuiteFurniture_Delete(slot, suiteid);

                    CancelEdit(playerid);
                    EditSuiteFurniture[playerid][1] = -1;
                    EditSuiteFurniture[playerid][0] = -1;
                    break;
                }
                case FURNITURE_SELECT_STORE: {
                    if (SuiteFurniture[suiteid][slot][suitefurnUnused])
                        return Error(playerid, "This furniture already stored."), CancelEdit(playerid);
                    
                    SuiteFurniture[suiteid][slot][suitefurnUnused] = 1;
                    SuiteFurniture_Refresh(slot, suiteid);
                    SuiteFurniture_Save(slot, suiteid);
                    SendCustomMessage(playerid, "FURNITURE", "You have stored furniture \"%s"WHITE_E"\" into your suiteroom.", SuiteFurniture[suiteid][slot][suitefurnName]);
                    break;
                }
            }
		}
	}
	if (EditSuiteStructure[playerid][1] != -1) 
	{
    	new suiteid = EditSuiteStructure[playerid][1];
		switch (SelectSuiteType[playerid]) {
		case STRUCTURE_SELECT_EDITOR: {
			foreach (new i : SuiteStructures[suiteid]) if (SuiteStructure[suiteid][i][suitestructObject] == objectid) {
                EditSuiteStructure[playerid][0] = i;
                EditSuiteStructure[playerid][1] = suiteid;
                EditDynamicObject(playerid, objectid);
                SendCustomMessage(playerid, "SUITEROOM", "You're now editing %s.", GetStructureNameByModel(SuiteStructure[suiteid][i][suitestructModel]));
                break;
			}
		}
		case STRUCTURE_SELECT_RETEXTURE: {
			foreach (new i : SuiteStructures[suiteid]) if (SuiteStructure[suiteid][i][suitestructObject] == objectid) {
                EditSuiteStructure[playerid][0] = i;
                EditSuiteStructure[playerid][1] = suiteid;
                CancelEdit(playerid);
                Dialog_Show(playerid, Dialog_SuiteRetexture, DIALOG_STYLE_INPUT, "Retexture Suite Structure", "Please input the texture name below:\n"YELLOW_E"[model] [txdname] [texture] [opt: alpha] [opt: red] [opt: green] [opt: blue]", "Retexture", "Cancel");
                break;
			}
		}
		case STRUCTURE_SELECT_DELETE: {
			foreach (new i : SuiteStructures[suiteid]) if (SuiteStructure[suiteid][i][suitestructObject] == objectid) {
                SendCustomMessage(playerid, "SUITEROOM", "You've deleted %s", GetStructureNameByModel(SuiteStructure[suiteid][i][suitestructModel]));
                SuiteStructure_Delete(suiteid, i);
                break;
			}
		}
		case STRUCTURE_SELECT_COPY: {
			foreach (new i : SuiteStructures[suiteid]) if (SuiteStructure[suiteid][i][suitestructObject] == objectid) {
                new price;

                for (new id = 0; id < sizeof(g_aHouseStructure); id ++) if (g_aHouseStructure[id][e_StructureModel] == SuiteStructure[suiteid][i][suitestructModel]) {
                    price = g_aHouseStructure[id][e_StructureCost];
                }

                if (pData[playerid][pComponent] < price)
                    return Error(playerid, "You need %d Component(s) to copy this structure.", price);

                new copyId = SuiteStructure_Copy(suiteid, i);

                if (copyId == cellmin)
                    return Error(playerid, "Your suiteroom has reached maximum of structure");
                
                pData[playerid][pComponent] -= price;
                EditSuiteStructure[playerid][0] = copyId;
                EditSuiteStructure[playerid][1] = suiteid;
                EditDynamicObject(playerid, SuiteStructure[suiteid][copyId][suitestructObject]);
                SendCustomMessage(playerid, "BUILDER", "You have copied structure for "GREEN_E"%d component(s)", price);
                SendCustomMessage(playerid, "BUILDER", "You're now editing copied object of %s.", GetStructureNameByModel(SuiteStructure[suiteid][i][suitestructModel]));
                break;
                }
            }
		}
	}
	return 1;
}
